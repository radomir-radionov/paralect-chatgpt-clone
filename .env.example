## Supabase (required)
# Get these from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

## Supabase Admin (recommended)
# Server-only key. Required for any admin operations performed by the app.
SUPABASE_SECRET_KEY=

## AI provider keys (pick at least one if using chat)
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

## Unstructured (optional)
# Only required if you use features that call the Unstructured API.
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=

## Chat UX tuning (optional)
# Set to "0" to disable paced assistant reveal.
NEXT_PUBLIC_CHAT_PACING=1


# Postgres (Supabase: Project Settings → Database → URI)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Supabase project URL and keys (Settings → API)
# Use NEXT_PUBLIC_SUPABASE_URL — the server reuses it as SUPABASE_URL (no separate SUPABASE_URL needed).
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=seyJ...
SUPABASE_ANON_KEY=seyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Random secret for signing anonymous session cookies (min 32 chars)
ANON_SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Google AI Studio — used for chat (Gemini) and for document upload / RAG (Gemini embeddings text-embedding-004).
# At least one LLM provider is still required for chat: this key, or OPENAI_API_KEY, or OpenAI-compatible env (see README).
GOOGLE_GENERATIVE_AI_API_KEY=


# Optional: public URL for OAuth redirects in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
